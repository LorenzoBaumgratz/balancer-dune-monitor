# ─────────────────────────────────────────────────────────────────────────────
# Balancer Dune Monitor — environment variables
#
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your Dune API key below
#   3. Never commit .env — it is in .gitignore
#
# Get a free Dune API key at: https://dune.com/settings/api
# ─────────────────────────────────────────────────────────────────────────────

DUNE_API_KEY=your_dune_api_key_here
